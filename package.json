{
  "name": "copy-as-markdown",
  "version": "2.0.0",
  "description": "Copy Link or Image as Markdown code, a Web Extension",
  "type": "module",
  "engines": {
    "node": ">= 20.0"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e:build": "npm run build && node scripts/build-test-extension.js",
    "test:e2e": "npm run test:e2e:build && playwright test",
    "test:e2e:headed": "npm run test:e2e:build && playwright test --headed",
    "test:e2e:ui": "npm run test:e2e:build && playwright test --ui",
    "test:e2e:debug": "npm run test:e2e:build && playwright test --debug",
    "test:e2e:docker": "docker build -t copy-as-markdown-playwright -f docker/playwright-ci/Dockerfile . && docker run --rm -it --ipc=host -p 9323:9323 copy-as-markdown-playwright",
    "bump-version": "node scripts/bump-version.js",
    "typecheck": "tsc",
    "build": "npm run build-chrome && npm run build-firefox-mv3",
    "build-chrome": "node scripts/build.js chrome && node scripts/assert-no-turndown.js",
    "build-firefox-mv3": "node scripts/build.js firefox-mv3",
    "package": "npm run package-chrome && npm run package-firefox-mv3",
    "package-chrome": "npm run build-chrome && zip -r build/chrome.zip chrome/ -x \"*.DS_Store\" -x \".keep\"",
    "package-firefox-mv3": "npm run build-firefox-mv3 && npx web-ext build -s firefox-mv3/ -a build/firefox-mv3/",
    "debug-chrome": "node scripts/debug.js chrome",
    "debug-edge": "node scripts/debug.js edge",
    "debug-firefox-mv3": "node scripts/debug.js firefox-mv3",
    "debug-firefox-deved": "node scripts/debug.js firefox-deved",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "clean": "rm -rf ./build/* ./{firefox-mv3,chrome}/dist/* ./{firefox-test,chrome-test,chrome-optional-test}/*",
    "convert-images": "./scripts/convert-images.sh",
    "postinstall": "node scripts/postinstall.js",
    "test:unit": "vitest --project unit",
    "test:browser": "vitest --project browser"
  },
  "license": "MIT",
  "dependencies": {
    "mustache": "^4.2.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^5.4.1",
    "@playwright/test": "^1.57.0",
    "@truto/turndown-plugin-gfm": "^1.0.2",
    "@types/chrome": "^0.1.31",
    "@types/firefox-webext-browser": "^143.0.0",
    "@types/mustache": "^4.2.6",
    "@types/turndown": "^5.0.5",
    "@vitest/browser": "^4.1.8",
    "@vitest/ui": "^3.2.4",
    "bulma": "^1.0.0",
    "esbuild": "^0.28.0",
    "eslint": "^9.37.0",
    "eslint-config-prettier": "^10.1.8",
    "http-server": "^14.1.1",
    "playwright": "^1.57.0",
    "tsx": "^4.20.6",
    "turndown": "^7.1.3",
    "typescript": "^5.4.0",
    "vitest": "^3.2.4",
    "webextension-polyfill": "^0.12.0"
  }
}
